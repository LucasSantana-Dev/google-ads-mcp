# Google Ads MCP — credentials (copy to .env and fill in; .env is gitignored)
# See README.md "Setup" for how to obtain each value.

# Required ---------------------------------------------------------------
GOOGLE_ADS_DEVELOPER_TOKEN=          # 22-char token from https://ads.google.com/aw/apicenter
GOOGLE_ADS_CLIENT_ID=                # OAuth2 Desktop App client id (Google Cloud Console)
GOOGLE_ADS_CLIENT_SECRET=            # OAuth2 client secret
GOOGLE_ADS_REFRESH_TOKEN=           # from scripts/get_refresh_token.py (one-time)

# Optional ---------------------------------------------------------------
GOOGLE_ADS_LOGIN_CUSTOMER_ID=        # manager (MCC) account id, digits only, no hyphens
GOOGLE_ADS_USE_PROTO_PLUS=True       # keep True; controls google-ads message types

# Write tools (Phase 2+) -------------------------------------------------
# EMPTY = all writes blocked (safe default). Add only accounts you intend to mutate.
GOOGLE_ADS_MUTATE_ALLOWLIST=         # comma-separated customer ids allowed to mutate
GOOGLE_ADS_AUDIT_LOG=audit-log.jsonl # append-only log of every confirmed mutation
